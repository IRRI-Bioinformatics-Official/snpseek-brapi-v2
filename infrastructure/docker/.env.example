# Copy this file to .env and fill in values before running docker compose up.
# .env is gitignored — never commit real credentials.

# ── Remote PostgreSQL ─────────────────────────────────────────────────────────
# Hostname or IP address of your remote Postgres server.
DB_HOST=your-postgres-host-or-ip
DB_PORT=5432
DB_NAME=snpseek
DB_USER=snpseek
DB_PASSWORD=change_me
